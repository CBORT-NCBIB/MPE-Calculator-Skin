        {
          "wl_min_nm": 1050,
          "wl_max_nm": 1400,
          "type": "constant",
          "value": 5.0,
          "note": "1050 ≤ λ ≤ 1400 nm: C_A = 5.0"
        }
      ]
    }
  },

