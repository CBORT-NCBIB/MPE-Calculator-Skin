      "regions": [
        {
          "wl_min_nm": 400,
          "wl_max_nm": 700,
          "type": "constant",
          "value": 1.0,
          "note": "400 ≤ λ < 700 nm: C_A = 1.0"
        },
        {
          "wl_min_nm": 700,
          "wl_max_nm": 1050,
          "type": "power10",
          "coefficient": 0.002,
          "offset_nm": 700,
          "note": "C_A = 10^(0.002(λ − 700))"
